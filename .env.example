# Server
PORT=3000
TURSO_URL=
TURSO_AUTH_TOKEN=

# Firebase (optional)
# Put firebase-admin-key.json near server.js

# Email (recommended: Resend SMTP or any SMTP provider)
# Example for Resend SMTP:
# EMAIL_SMTP_HOST=smtp.resend.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=resend
# EMAIL_SMTP_PASS=re_xxxxxxxxxxxxxxxxx
# EMAIL_FROM_NAME=Lumyn
# EMAIL_FROM_ADDRESS=no-reply@lumyn.space

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_NAME=Lumyn
EMAIL_FROM_ADDRESS=

# DEV ONLY: when true, backend prints verification code to logs if SMTP fails.
# Keep false in production.
EMAIL_ALLOW_LOG_FALLBACK=false
